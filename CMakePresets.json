{
    "version": 6,
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build_${presetName}",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "base-ninja",
            "hidden": true,
            "inherits": "base",
            "condition": {
                "type": "notEquals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "base-msvc",
            "hidden": true,
            "generator": "Visual Studio 17 2022",
            "binaryDir": "${sourceDir}/build_msvc",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "ninja",
            "inherits": "base-ninja",
            "displayName": "Debug (Ninja)",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "ninja-release",
            "inherits": "base-ninja",
            "displayName": "Release (Ninja)",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "ninja-tutorials",
            "inherits": "ninja",
            "displayName": "Debug + Tutorials",
            "cacheVariables": {
                "BUILD_TUTORIALS": "ON"
            }
        },
        {
            "name": "ninja-samples",
            "inherits": "ninja",
            "displayName": "Debug + Samples",
            "cacheVariables": {
                "BUILD_SAMPLES": "ON"
            }
        },
        {
            "name": "msvc",
            "inherits": "base-msvc",
            "displayName": "Visual Studio 2022"
        },
        {
            "name": "msvc-tutorials",
            "inherits": "msvc",
            "displayName": "VS 2022 + Tutorials",
            "cacheVariables": {
                "BUILD_TUTORIALS": "ON"
            }
        },
        {
            "name": "msvc-samples",
            "inherits": "msvc",
            "displayName": "VS 2022 + Samples",
            "cacheVariables": {
                "BUILD_SAMPLES": "ON"
            }
        }
    ],
    "buildPresets": [
        { "name": "ninja",           "configurePreset": "ninja" },
        { "name": "ninja-release",   "configurePreset": "ninja-release" },
        { "name": "ninja-tutorials", "configurePreset": "ninja-tutorials" },
        { "name": "ninja-samples",   "configurePreset": "ninja-samples" },
        { "name": "msvc",            "configurePreset": "msvc",           "configuration": "Debug" },
        { "name": "msvc-release",    "configurePreset": "msvc",           "configuration": "Release" },
        { "name": "msvc-tutorials",  "configurePreset": "msvc-tutorials", "configuration": "Debug" },
        { "name": "msvc-samples",    "configurePreset": "msvc-samples",   "configuration": "Debug" }
    ]
}
